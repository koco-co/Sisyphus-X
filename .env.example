# ==============================
# Sisyphus-X Environment Template
# ==============================
# This is the unified environment variable reference.
# Actual .env files are located in:
#   - backend/.env   (backend configuration)
#   - frontend/.env  (frontend configuration)
# Copy the relevant sections to the corresponding .env files.

# ===== Backend Configuration (backend/.env) =====

# --- Application ---
PROJECT_NAME="Sisyphus X"
API_V1_STR="/api/v1"
FRONTEND_URL="http://localhost:5173"
API_DOMAIN="http://localhost:8000"

# --- Security ---
SECRET_KEY="change-me-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_DISABLED=true

# --- Database ---
# SQLite (development):
DATABASE_URL="sqlite+aiosqlite:///./sisyphus.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql+asyncpg://sisyphus:sisyphus123@localhost:5432/sisyphus"

# --- Redis ---
REDIS_URL="redis://localhost:6379/0"

# --- MinIO ---
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="sisyphus-assets"
MINIO_USE_SSL=false
MINIO_SECURE=false

# --- OAuth (optional) ---
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Encryption ---
ENCRYPTION_KEY=""

# ===== Frontend Configuration (frontend/.env) =====

VITE_API_BASE_URL="http://localhost:8000/api/v1"
VITE_AUTH_DISABLED=true
VITE_DEV_MODE_SKIP_LOGIN=true
