# Sisyphus-X Frontend Environment Configuration
# Copy to .env and adjust for your local environment.

# API Base URL
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Auth (set to 'true' to disable authentication in development)
VITE_AUTH_DISABLED=true

# Dev Mode (skip login for development)
VITE_DEV_MODE_SKIP_LOGIN=true
